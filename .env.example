# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stockage médias (requis en prod — plugin activé si présent)
BLOB_READ_WRITE_TOKEN=

# Email
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
